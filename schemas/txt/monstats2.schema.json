{
  "file": "monstats2.txt",
  "description": "Monster visual and collision properties — animation components, light settings, hit testing, and display flags. Referenced by MonStatsEx column in MonStats.txt.",
  "columns": {
    "Height": {
      "type": "integer",
      "description": "Monster height in pixels (used for overlay positioning)",
      "engineVerified": true
    },
    "overlayHeight": {
      "type": "integer",
      "description": "Overlay effect height offset in pixels",
      "engineVerified": true
    },
    "pixHeight": {
      "type": "integer",
      "description": "Pixel height (unused in 1.10+)",
      "engineVerified": true
    },
    "spawnCol": {
      "type": "integer",
      "description": "Spawn collision mode (0 = normal, 1 = DS1 only, 2 = special)",
      "engineVerified": true
    },
    "MeleeRng": {
      "type": "integer",
      "description": "Melee attack range in sub-tiles",
      "engineVerified": true
    },
    "TotalPieces": {
      "type": "integer",
      "description": "Total number of animation component pieces",
      "engineVerified": true
    },
    "noGfxHitTest": {
      "type": "boolean",
      "description": "Disable pixel-accurate hit testing, use bounding box only",
      "engineVerified": true
    },
    "htWidth": {
      "type": "integer",
      "description": "Hit test bounding box width",
      "engineVerified": true
    },
    "htHeight": {
      "type": "integer",
      "description": "Hit test bounding box height",
      "engineVerified": true
    },
    "automapCel": {
      "type": "integer",
      "description": "Automap icon cell index",
      "engineVerified": true
    },
    "noMap": {
      "type": "boolean",
      "description": "Do not display on automap",
      "engineVerified": true
    },
    "isSel": {
      "type": "boolean",
      "description": "Monster is selectable (default)",
      "engineVerified": true
    },
    "isAtt": {
      "type": "boolean",
      "description": "Monster is attackable",
      "engineVerified": true
    },
    "critter": {
      "type": "boolean",
      "description": "Monster is a critter (passive, non-hostile)",
      "engineVerified": true
    },
    "deadCol": {
      "type": "boolean",
      "description": "Corpse has collision",
      "engineVerified": true
    },
    "unflatDead": {
      "type": "boolean",
      "description": "Corpse is not flattened on ground",
      "engineVerified": true
    },
    "noUniqueShift": {
      "type": "boolean",
      "description": "Disable unique monster color palette shift",
      "engineVerified": true
    },
    "localBlood": {
      "type": "integer",
      "description": "Blood color (0 = none, 1 = blood, 2 = no blood)",
      "engineVerified": true
    },
    "light": {
      "type": "integer",
      "description": "Light radius diameter in sub-tiles",
      "engineVerified": true
    },
    "InfernoLen": {
      "type": "integer",
      "description": "Inferno sub-animation frame length",
      "engineVerified": true
    },
    "InfernoAnim": {
      "type": "integer",
      "description": "Animation mode used for inferno effect",
      "engineVerified": true
    },
    "InfernoRollback": {
      "type": "integer",
      "description": "Inferno animation rollback frame length",
      "engineVerified": true
    },
    "ResurrectMode": {
      "type": "enum",
      "description": "Animation mode token used when resurrected",
      "values": [
        "DT",
        "NU",
        "WL",
        "GH",
        "A1",
        "A2",
        "BL",
        "SC",
        "S1",
        "S2",
        "S3",
        "S4",
        "DD",
        "KB",
        "xx",
        "RN",
        ""
      ],
      "engineVerified": true
    },
    "ResurrectSkill": {
      "type": "ref",
      "target": "skills.txt",
      "targetColumn": "skill",
      "description": "Skill used when monster resurrects",
      "engineVerified": true
    },
    "montype": {
      "type": "string",
      "description": "Column read by game engine",
      "engineVerified": true
    },
    "BaseW": {
      "type": "integer",
      "description": "Base weapon class",
      "engineVerified": true
    },
    "Id": {
      "type": "string",
      "description": "Monster stats2 identifier",
      "required": true,
      "engineVerified": true
    },
    "SizeX": {
      "type": "integer",
      "description": "Horizontal collision size",
      "engineVerified": true
    },
    "SizeY": {
      "type": "integer",
      "description": "Vertical collision size",
      "engineVerified": true
    }
  }
}