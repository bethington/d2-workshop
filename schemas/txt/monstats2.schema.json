{
  "file": "monstats2.txt",
  "description": "Monster visual and collision properties \u2014 animation components, light settings, hit testing, and display flags. Referenced by MonStatsEx column in MonStats.txt.",
  "columns": {
    "Id": {
      "type": "string",
      "required": true,
      "unique": true,
      "description": "Monster identifier, referenced by MonStatsEx column in MonStats.txt"
    },
    "Height": {
      "type": "integer",
      "description": "Monster height in pixels (used for overlay positioning)"
    },
    "OverlayHeight": {
      "type": "integer",
      "description": "Overlay effect height offset in pixels"
    },
    "pixHeight": {
      "type": "integer",
      "description": "Pixel height (unused in 1.10+)"
    },
    "SizeX": {
      "type": "integer",
      "description": "Collision box X diameter in sub-tiles"
    },
    "SizeY": {
      "type": "integer",
      "description": "Collision box Y diameter in sub-tiles"
    },
    "spawnCol": {
      "type": "integer",
      "description": "Spawn collision mode (0 = normal, 1 = DS1 only, 2 = special)"
    },
