{
  "file": "itemtypes.txt",
  "description": "Item type hierarchy \u00e2\u20ac\u201d defines equipment categories, socket rules, and class restrictions.",
  "columns": {
    "ItemType": {
      "type": "string",
      "required": true,
      "description": "Display name of the item type category"
    },
    "Code": {
      "type": "string",
      "description": "Unique 3-4 character item code"
    },
    "Order": {
      "type": "integer",
      "description": "Sort order priority for inventory display",
      "min": 0
    },
    "Equiv1": {
      "type": "ref",
      "target": "itemtypes.txt",
      "targetColumn": "Code",
      "description": "Equivalent item type 1 (parent in type hierarchy)"
    },
    "Equiv2": {
      "type": "enum",
      "values": [
        "amaz",
        "assn",
        "axe",
        "barb",
        "drui",
        "knif",
        "mpot",
        "necr",
        "pala",
        "seco",
        "sorc",
        "spea",
        "thro"
      ],
      "description": "Secondary parent item type code in the type hierarchy"
    },
    "Identify": {
      "type": "boolean",
      "description": "Whether items of this type require identification"
    },
    "Repair": {
      "type": "boolean",
      "description": "Item can be repaired"
    },
    "Mods": {
      "type": "boolean",
      "description": "Whether items of this type can receive magical modifiers"
    },
    "Body": {
      "type": "boolean",
      "description": "Equippable on body slot"
    },
    "BodyLoc1": {
      "type": "enum",
      "values": [
        "head",
        "neck",
        "tors",
        "rarm",
        "larm",
        "rrin",
        "lrin",
        "belt",
        "feet",
        "glov",
        ""
      ],
      "description": "Primary equipment slot location"
    },
    "BodyLoc2": {
      "type": "enum",
      "values": [
        "head",
        "neck",
        "tors",
        "rarm",
        "larm",
        "rrin",
        "lrin",
        "belt",
        "feet",
        "glov",
        ""
      ],
      "description": "Secondary equipment slot location"
    },
    "Shoots": {
      "type": "enum",
      "values": [
        "bowq",
        "xboq"
      ],
      "description": "Ammunition item type code this weapon fires (e.g. bowq, xboq)"
    },
    "Quiver": {
      "type": "enum",
      "values": [
        "bow",
        "xbow"
      ],
      "description": "Weapon type code this ammo is used with (e.g. bow, xbow)"
    },
    "Throwable": {
      "type": "boolean",
      "description": "Item can be thrown"
    },
    "Reload": {
      "type": "boolean",
      "description": "Whether this item type auto-reloads ammunition from inventory"
    },
    "ReEquip": {
      "type": "boolean",
      "description": "Whether this item type auto-re-equips when quantity is replenished"
    },
    "AutoStack": {
      "type": "boolean",
      "description": "Whether this item type automatically stacks in inventory"
    },
    "Magic": {
      "type": "boolean",
      "description": "Whether items of this type can spawn as magic quality"
    },
    "Rare": {
      "type": "boolean",
      "description": "Can spawn as rare quality"
    },
    "Normal": {
      "type": "boolean",
      "description": "Whether items of this type can spawn as normal quality"
    },
    "Charm": {
      "type": "boolean",
      "description": "Whether this item type functions as a charm (passive effect in inventory)"
    },
    "Gem": {
      "type": "boolean",
      "description": "Whether this item type functions as a gem/rune for socketing"
    },
    "Beltable": {
      "type": "boolean",
      "description": "Can be placed in belt"
    },
    "MaxSock1": {
      "type": "integer",
      "min": 0,
      "max": 5,
      "description": "Maximum number of sockets for items at low level (1-25)"
    },
    "MaxSock25": {
      "type": "integer",
      "min": 0,
      "max": 6,
      "description": "Maximum number of sockets for items at mid level (25-40)"
    },
    "MaxSock40": {
      "type": "integer",
      "min": 0,
      "max": 6,
      "description": "Maximum number of sockets for items at high level (40+)"
    },
    "TreasureClass": {
      "type": "boolean",
      "description": "Item drop classification reference"
    },
    "Rarity": {
      "type": "integer",
      "min": 1,
      "max": 3,
      "description": "Spawn rarity ratio (1/N chance)"
    },
    "StaffMods": {
      "type": "enum",
      "values": [
        "ass",
        "bar",
        "dru",
        "nec",
        "pal",
        "sor"
      ],
      "description": "Staff auto-mod skill group"
    },
    "CostFormula": {
      "type": "integer",
      "min": 0,
      "max": 2,
      "description": "Cost calculation formula type (0 = standard, 1 = armor, 2 = weapon)"
    },
    "Class": {
      "type": "enum",
      "values": [
        "ama",
        "ass",
        "bar",
        "dru",
        "nec",
        "pal",
        "sor"
      ],
      "description": "Character class restriction"
    },
    "VarInvGfx": {
      "type": "integer",
      "min": 0,
      "max": 6,
      "description": "Number of inventory graphic variations"
    },
    "InvGfx1": {
      "type": "enum",
      "values": [
        "invamu1",
        "invch1",
        "invch2",
        "invch3",
        "invjw1",
        "invrin1"
      ],
      "description": "Inventory graphic variation 1"
    },
    "InvGfx2": {
      "type": "enum",
      "values": [
        "invamu2",
        "invch4",
        "invch5",
        "invch6",
        "invjw2",
        "invrin2"
      ],
      "description": "Inventory graphic variation 2"
    },
    "InvGfx3": {
      "type": "enum",
      "values": [
        "invamu3",
        "invch7",
        "invch8",
        "invch9",
        "invjw3",
        "invrin3"
      ],
      "description": "Inventory graphic variation 3"
    },
    "InvGfx4": {
      "type": "enum",
      "values": [
        "invjw4",
        "invrin4"
      ],
      "description": "Inventory graphic variation 4"
    },
    "InvGfx5": {
      "type": "enum",
      "values": [
        "invjw5",
        "invrin5"
      ],
      "description": "Inventory graphic variation 5"
    },
    "InvGfx6": {
      "type": "string",
      "description": "Inventory graphic variation 6"
    },
    "StorePage": {
      "type": "enum",
      "values": [
        "armo",
        "mag",
        "misc",
        "weap"
      ],
      "description": "NPC store tab page"
    }
  }
}