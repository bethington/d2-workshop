    "MaxHP": {
      "type": "integer",
      "min": 0,
      "description": "Maximum hit points (Normal)"
    },
    "MinHP(N)": {
      "type": "integer",
      "min": 0,
      "description": "Minimum hit points (Nightmare)"
    },
    "MaxHP(N)": {
      "type": "integer",
      "min": 0,
      "description": "Maximum hit points (Nightmare)"
    },
    "MinHP(H)": {
      "type": "integer",
      "min": 0,
      "description": "Minimum hit points (Hell)"
