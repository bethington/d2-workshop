{
  "file": "monstats.txt",
  "description": "Monster statistics \u00e2\u20ac\u201d defines all monster types, their stats, AI, drops, and visual properties. 229 columns.",
  "columns": {
    "Class": {
      "type": "string",
      "required": true,
      "description": "Internal monster class name (referenced by other tables)"
    },
    "namco": {
      "type": "string",
      "description": "String table key for display name"
    },
    "Type": {
      "type": "ref",
      "target": "MonType.txt",
      "targetColumn": "type",
      "description": "Monster type classification"
    },
    "BaseId": {
      "type": "ref",
      "target": "monstats.txt",
      "targetColumn": "Class",
      "description": "Base monster class (for variants)"
    },
    "Code": {
      "type": "string",
      "required": true,
      "description": "2-character token used in animation file paths"
    },
    "Spawned": {
      "type": "boolean",
      "description": "Can be spawned by other monsters (1 = yes)"
    },
    "SizeX": {
      "type": "integer",
      "min": 0,
      "description": "Tile footprint width"
    },
    "SizeY": {
      "type": "integer",
      "min": 0,
      "description": "Tile footprint height"
    },
    "Velocity": {
      "type": "integer",
      "min": 0,
