      "min": 0,
      "description": "Armor class / defense (Normal)"
    },
    "Exp": {
      "type": "integer",
      "min": 0,
      "description": "Base experience points (Normal)"
    },
    "Exp(N)": {
      "type": "integer",
      "min": 0,
      "description": "Base experience points (Nightmare)"
