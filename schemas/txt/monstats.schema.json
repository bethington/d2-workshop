      "min": 0,
      "description": "Attack 1 maximum damage (Normal)"
    },
    "El1Mode": {
      "type": "enum",
      "description": "Elemental attack 1 mode",
      "values": [
        "DT",
        "NU",
        "WL",
        "GH",
        "A1",
        "A2",
        "BL",
        "SC",
        "S1",
        "S2",
        "S3",
        "S4",
        "DD",
        "KB",
        "xx",
        "RN",
