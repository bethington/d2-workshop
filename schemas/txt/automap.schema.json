{
  "file": "automap.txt",
  "description": "Automap cell type definitions mapping tiles to minimap graphics.",
  "columns": {
    "LevelName": {
      "type": "string",
      "required": true,
      "description": "Display name string key"
    },
    "TileName": {
      "type": "enum",
      "values": [
        "co",
        "fl",
        "wbl",
        "wbr",
        "wl",
        "wld",
        "wle",
        "wr",
        "wrd",
        "wre",
        "wtll",
        "wtlr",
        "wtr"
      ],
      "description": "Tile orientation type code (e.g. fl=floor, wl=wall left, co=corner)"
    },
    "Style": {
      "type": "integer",
      "min": 0,
      "max": 49,
      "description": "Visual style index for the automap tile"
    },
    "StartSequence": {
      "type": "integer",
      "min": -1,
      "max": 63,
      "description": "Starting animation sequence index (-1 = none)"
    },
    "EndSequence": {
      "type": "integer",
      "min": -1,
      "max": 63,
      "description": "Ending animation sequence index (-1 = none)"
    },
    "Type1": {
      "type": "string",
      "description": "Primary automap cell type name"
    },
    "Cel1": {
      "type": "integer",
      "min": 0,
      "max": 1254,
      "description": "Primary automap cell graphic index"
    },
    "Type2": {
      "type": "enum",
      "values": [
        "C_WL c",
        "C_WR c",
        "Cave LC",
        "Cave RC",
        "Floor Path C",
        "River M C",
        "River_C",
        "rock4",
        "tree03"
      ],
      "description": "Secondary automap cell type name"
    },
    "Cel2": {
      "type": "integer",
      "min": -1,
      "max": 534,
      "description": "Secondary automap cell graphic index (-1 = none)"
    },
    "Cel3": {
      "type": "integer",
      "min": -1,
      "max": 522,
      "description": "Tertiary automap cell graphic index (-1 = none)"
    },
    "Type4": {
      "type": "enum",
      "values": [
        "C_WL d",
        "C_WR d",
        "Floor Path D",
        "tree04"
      ],
      "description": "Quaternary automap cell type name"
    },
    "Cel4": {
      "type": "integer",
      "min": -1,
      "max": 475,
      "description": "Quaternary automap cell graphic index (-1 = none)"
    }
  }
}
