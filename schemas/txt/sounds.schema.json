{
  "file": "sounds.txt",
  "description": "Sound effect definitions \u2014 file references, volume, looping, and fade settings.",
  "columns": {
    "Handle": {
      "type": "string",
      "required": true,
      "description": "Sound effect name/handle identifier"
    },
    "Index": {
      "type": "integer",
      "min": 0,
      "max": 3586,
      "description": "Unique index identifier"
    },
    "FileName": {
      "type": "string",
      "description": "Audio file reference"
    },
    "Volume": {
      "type": "integer",
      "min": 0,
      "max": 255,
      "description": "Playback volume (0-255)"
    },
    "Group Size": {
      "type": "integer",
      "min": 0,
      "max": 8,
      "description": "Maximum simultaneous playback instances"
    },
    "Loop": {
      "type": "boolean",
      "description": "Enable looping playback"
    },
    "Fade In": {
      "type": "integer",
      "min": 0,
      "max": 125,
      "description": "Fade-in duration in frames"
    },
    "Fade Out": {
      "type": "integer",
      "min": 0,
      "max": 125,
      "description": "Fade-out duration in frames"
    },
    "Defer Inst": {
      "type": "boolean",
      "description": "Deferred instantiation flag"
    },
    "Stop Inst": {
      "type": "boolean",
      "description": "Stop other instances when playing"
    },
    "Duration": {
      "type": "integer",
      "min": 0,
      "max": 150,
      "description": "Playback duration (milliseconds)"
    },
    "Compound": {
      "type": "integer",
      "min": -1,
      "max": 24,
      "description": "Compound sound priority"
    },
    "Reverb": {
      "type": "boolean",
      "description": "Reverb effect enabled"
    },
    "Falloff": {
      "type": "integer",
      "min": 0,
      "max": 4,
      "description": "Distance falloff rate"
    },
    "Cache": {
      "type": "boolean",
      "description": "Cache sound in memory"
    },
    "Async Only": {
      "type": "boolean",
      "description": "Asynchronous playback only"
    },
    "Priority": {
      "type": "integer",
      "min": 0,
      "max": 255,
      "description": "Playback priority (0-255, higher = more important)"
    },
    "Stream": {
      "type": "boolean",
      "description": "Stream from disk instead of loading into memory"
    },
    "Stereo": {
      "type": "boolean",
      "description": "Stereo audio playback"
    },
    "Tracking": {
      "type": "boolean",
      "description": "Position tracking enabled"
    },
    "Solo": {
      "type": "boolean",
      "description": "Solo playback (mute others)"
    },
    "Music Vol": {
      "type": "boolean",
      "description": "Use music volume slider"
    },
    "Block 1": {
      "type": "integer",
      "min": -1,
      "max": 6381568,
      "description": "Sound block 1 reference"
    },
    "Block 2": {
      "type": "integer",
      "min": -1,
      "max": 7000000,
      "description": "Sound block 2 reference"
    },
    "Block 3": {
      "type": "integer",
      "min": -1,
      "max": -1,
      "description": "Sound block 3 reference"
    }
  }
