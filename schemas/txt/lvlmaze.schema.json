{
  "file": "lvlmaze.txt",
  "description": "Level maze generation parameters.",
  "columns": {
    "Name": {
      "type": "string",
      "required": true,
      "unique": true,
      "description": "Internal name identifier"
    },
    "Level": {
      "type": "integer",
      "description": "Level ID this maze configuration applies to",
      "min": 0
    },
    "Rooms": {
      "type": "integer",
      "min": 1,
      "max": 61,
      "description": "Number of rooms in the maze"
    },
    "SizeX": {
      "type": "integer",
      "min": 8,
      "max": 24,
      "description": "Width in grid cells"
    },
    "SizeY": {
      "type": "integer",
      "min": 8,
      "max": 24,
      "description": "Height in grid cells"
    },
    "Merge": {
      "type": "integer",
      "min": 0,
      "max": 1000,
      "description": "Room merge probability (0-1000)"
    },
    "Beta": {
      "type": "boolean",
      "description": "Beta content flag (unused)"
    }
  }
}
