{
  "file": "lvlprest.txt",
  "description": "Level preset definitions — pre-built map sections.",
  "columns": {
    "Name": {
      "type": "string",
      "required": true,
      "unique": true,
      "description": "Internal name identifier"
    },
    "Def": {
      "type": "integer",
      "min": 0,
      "max": 862,
      "description": "Default preset definition index"
    },
    "LevelId": {
      "type": "string",
      "description": "Reference to level ID in Levels.txt that uses this preset"
    },
    "Populate": {
      "type": "boolean",
      "description": "Whether to populate this preset with monsters and objects"
    },
    "Logicals": {
      "type": "boolean",
      "description": "Whether logical connections between tiles are enforced"
    },
    "Outdoors": {
      "type": "boolean",
      "description": "Whether this preset is used for outdoor areas"
    },
    "Animate": {
      "type": "boolean",
      "description": "Whether animated tiles are enabled in this preset"
    },
    "KillEdge": {
      "type": "boolean",
      "description": "Whether to remove edge tiles that overlap with adjacent presets"
    },
    "FillBlanks": {
      "type": "boolean",
      "description": "Whether to fill blank spaces with floor tiles"
    },
    "SizeX": {
      "type": "integer",
      "min": 0,
      "max": 64,
      "description": "Width in grid cells"
    },
    "SizeY": {
      "type": "integer",
      "min": 0,
      "max": 56,
      "description": "Height in grid cells"
    },
    "AutoMap": {
      "type": "boolean",
      "description": "Automap display flag"
    },
    "Scan": {
      "type": "boolean",
      "description": "Scannable by abilities"
    },
    "Pops": {
      "type": "integer",
      "min": 0,
      "max": 4,
      "description": "Population density"
    },
    "PopPad": {
      "type": "integer",
      "min": -5,
      "max": 0,
      "description": "Padding distance for population placement from edges"
    },
    "Files": {
      "type": "integer",
      "min": 0,
      "max": 6,
      "description": "Number of DS1 map files used by this preset"
    },
    "File1": {
      "type": "string",
      "description": "DS1 map file path variant 1"
    },
    "File2": {
      "type": "string",
      "description": "DS1 map file path variant 2"
    },
    "File3": {
      "type": "string",
      "description": "DS1 map file path variant 3"
    },
    "File4": {
      "type": "string",
      "description": "DS1 map file path variant 4"
    },
    "File5": {
      "type": "string",
      "description": "DS1 map file path variant 5"
    },
    "File6": {
      "type": "enum",
      "values": [
        "0",
        "Act1/Outdoors/Cott6.ds1",
        "Act1/Outdoors/Cott6A.ds1",
        "Act2/Maggot/MagEW6.ds1",
        "Act2/Maggot/MagNEW4.ds1",
        "Act2/Maggot/MagNS6.ds1",
        "Act2/Maggot/MagNSE4.ds1",
        "Act2/Maggot/MagNSW4.ds1",
        "Act2/Maggot/MagSEW4.ds1",
        "Act2/Ruin/Ruin6.ds1",
        "Act3/Jungle/DungRm6A.ds1",
        "Act3/Jungle/DungRm6B.ds1"
      ],
      "description": "DS1 map file path variant 6"
    },
    "Dt1Mask": {
      "type": "integer",
      "min": 0,
      "max": 268435456,
      "description": "Bitmask controlling which DT1 tile files are loaded for this preset"
    },
    "Beta": {
      "type": "boolean",
      "description": "Beta content flag (unused)"
    }
  }
}
