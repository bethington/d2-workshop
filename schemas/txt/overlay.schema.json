{
  "file": "overlay.txt",
  "description": "Visual overlay definitions \u2014 particle effects, auras, and status indicators.",
  "columns": {
    "Overlay": {
      "type": "string",
      "required": true,
      "unique": true,
      "description": "Overlay identifier"
    },
    "Filename": {
      "type": "string",
      "description": "DCC/DC6 animation file reference"
    },
    "Frames": {
      "type": "integer",
      "min": 2,
      "max": 30,
      "description": "Number of animation frames"
    },
    "Character": {
      "type": "enum",
      "values": [
        "?",
        "Amazon",
        "Bar",
        "Monster",
        "Necro",
        "Paladin",
        "Sorceress",
        "all",
        "item",
        "npcs",
        "object",
        "objects",
        "test"
      ],
      "description": "Character or entity type this overlay applies to"
    },
    "PreDraw": {
      "type": "boolean",
      "description": "Pre-draw flag for rendering order"
    },
    "1ofN": {
      "type": "integer",
      "min": 1,
      "max": 3,
      "description": "Random variant selection (1 of N)"
    },
    "Dir": {
      "type": "boolean",
      "description": "Whether the overlay uses directional animations"
    },
    "Open": {
      "type": "boolean",
      "description": "Open/expanded state flag"
    },
    "Beta": {
      "type": "boolean",
      "description": "Beta content flag (unused)"
    },
    "Xoffset": {
      "type": "integer",
      "min": -10,
      "max": 10,
      "description": "Horizontal position offset in pixels"
    },
    "Yoffset": {
      "type": "integer",
      "min": -15,
      "max": 1,
      "description": "Vertical position offset in pixels"
    },
    "Height1": {
      "type": "integer",
      "min": -30,
      "max": 14,
      "description": "Height offset for overhead overlays"
    },
    "Height2": {
      "type": "integer",
      "min": 0,
      "max": 1,
      "description": "Height offset for medium overlays"
    },
    "Height3": {
      "type": "integer",
      "min": -14,
      "max": 0,
      "description": "Height offset for low overlays"
    },
    "Height4": {
      "type": "integer",
      "min": -60,
      "max": 0,
      "description": "Height offset for ground-level overlays"
    },
    "AnimRate": {
      "type": "integer",
      "min": 2,
      "max": 24,
      "description": "Animation playback rate"
    },
    "LoopWaitTime": {
      "type": "integer",
      "min": 0,
      "max": 7000,
      "description": "Wait time between loop iterations (frames)"
    },
    "Trans": {
      "type": "integer",
      "min": 3,
      "max": 8,
      "description": "Transparency blend mode"
    },
    "InitRadius": {
      "type": "integer",
      "min": 0,
      "max": 14,
      "description": "Initial effect radius"
    },
    "Radius": {
      "type": "integer",
      "min": 0,
      "max": 14,
      "description": "Effect radius"
    },
    "Red": {
      "type": "integer",
      "min": 0,
      "max": 255,
      "description": "Red color channel (0-255)"
    },
    "Green": {
      "type": "integer",
      "min": 0,
      "max": 255,
      "description": "Green color channel (0-255)"
    },
    "Blue": {
      "type": "integer",
      "min": 0,
      "max": 255,
      "description": "Blue color channel (0-255)"
    },
    "NumDirections": {
      "type": "integer",
      "min": 1,
      "max": 4,
      "description": "Number of animation directions"
    },
    "LocalBlood": {
      "type": "boolean",
      "description": "Local blood effect flag"
    }
  }
}
