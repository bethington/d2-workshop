      "min": -30,
      "max": 14,
      "description": "Height offset for overhead overlays",
      "engineVerified": true
    },
    "Height2": {
      "type": "integer",
      "min": 0,
      "max": 1,
      "description": "Height offset for medium overlays",
      "engineVerified": true
    },
    "Height3": {
      "type": "integer",
      "min": -14,
      "max": 0,
