      "type": "boolean",
      "description": "Whether overlay renders in open areas",
      "engineVerified": true
    },
    "Radius": {
      "type": "integer",
      "description": "Effect radius",
      "engineVerified": true
    },
    "Red": {
      "type": "integer",
      "description": "Red color component",
      "engineVerified": true
    },
    "Trans": {
      "type": "integer",
      "description": "Transparency level",
      "engineVerified": true
    },
    "isOverlay": {
      "type": "boolean",
      "description": "Whether this entry is an overlay type",
      "engineVerified": true
    }
  }
