{
  "file": "hireling.txt",
  "description": "Mercenary definitions \u00e2\u20ac\u201d stats, skills, level progression, and hiring costs per act and difficulty.",
  "columns": {
    "Hireling": {
      "type": "string",
      "required": true,
      "unique": true,
      "description": "Hireling type identifier"
    },
    "SubType": {
      "type": "string",
      "description": "Hireling sub-specialization type (e.g. Fire, Cold, Combat)"
    },
    "Id": {
      "type": "integer",
      "min": 0,
      "max": 29,
      "description": "Unique numeric ID"
    },
    "Class": {
      "type": "integer",
      "min": 271,
      "max": 561,
      "description": "Monster class animation index"
    },
    "Act": {
      "type": "integer",
      "min": 1,
      "max": 5,
      "description": "Act number (1-5)"
    },
    "Difficulty": {
      "type": "integer",
      "min": 1,
      "max": 3,
      "description": "Difficulty level (1=Normal, 2=Nightmare, 3=Hell)"
    },
    "Level": {
      "type": "integer",
      "min": 3,
      "max": 75,
      "description": "Hireling base level"
    },
    "Seller": {
      "type": "integer",
      "min": 150,
      "max": 515,
      "description": "NPC vendor reference"
    },
    "NameFirst": {
      "type": "enum",
      "values": [
        "MercX101",
        "merc01",
        "merca201",
        "merca222"
      ],
      "description": "Starting index in the hireling name table for first names"
    },
    "NameLast": {
      "type": "enum",
      "values": [
        "MercX167",
        "merc41",
        "merca221",
        "merca241"
      ],
      "description": "Ending index in the hireling name table for first names"
    },
    "Gold": {
      "type": "integer",
      "min": 100,
      "max": 32000,
      "description": "Base hiring gold cost"
    },
    "Exp/Lvl": {
      "type": "integer",
      "min": 100,
      "max": 125,
      "description": "Experience scaling ratio per level"
    },
    "HP": {
