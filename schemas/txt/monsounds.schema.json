{
  "file": "monsounds.txt",
  "description": "Monster sound assignments \u00e2\u20ac\u201d maps monster sound IDs to specific sound entries in Sounds.txt for attack, hit, death, and ambient events. Referenced by MonSound/UMonSound columns in MonStats.txt.",
  "columns": {
    "Id": {
      "type": "string",
      "required": true,
      "unique": true,
      "description": "Monster sound set identifier, referenced by MonStats.txt MonSound/UMonSound columns"
    },
    "Attack1": {
      "type": "ref",
      "target": "sounds.txt",
      "targetColumn": "Handle",
      "description": "Primary attack sound effect"
    },
    "Weapon1": {
      "type": "ref",
      "target": "sounds.txt",
      "targetColumn": "Handle",
      "description": "Primary weapon impact sound effect"
    },
    "Att1Del": {
      "type": "integer",
      "description": "Attack 1 sound delay in frames"
    },
    "Wea1Del": {
      "type": "integer",
      "description": "Weapon 1 sound delay in frames"
    },
    "Att1Prb": {
      "type": "integer",
      "description": "Attack 1 sound probability (0-100)"
    },
    "Wea1Vol": {
      "type": "integer",
      "description": "Weapon 1 sound volume (0-255)"
    },
    "Attack2": {
      "type": "ref",
      "target": "sounds.txt",
      "targetColumn": "Handle",
      "description": "Secondary attack sound effect"
    },
    "Weapon2": {
      "type": "ref",
      "target": "sounds.txt",
      "targetColumn": "Handle",
      "description": "Secondary weapon impact sound effect"
    },
    "Att2Del": {
      "type": "integer",
      "description": "Attack 2 sound delay in frames"
    },
    "Wea2Del": {
      "type": "integer",
      "description": "Weapon 2 sound delay in frames"
    },
    "Att2Prb": {
      "type": "integer",
      "description": "Attack 2 sound probability (0-100)"
    },
    "Wea2Vol": {
      "type": "integer",
      "description": "Weapon 2 sound volume (0-255)"
    },
    "HitSound": {
      "type": "ref",
      "target": "sounds.txt",
      "targetColumn": "Handle",
      "description": "Sound effect when monster is hit"
    },
    "DeathSound": {
      "type": "ref",
      "target": "sounds.txt",
      "targetColumn": "Handle",
      "description": "Sound effect when monster dies"
    },
    "HitDelay": {
      "type": "integer",
      "description": "Get-hit sound delay in frames"
    },
    "DeaDelay": {
      "type": "integer",
      "description": "Death sound delay in frames"
    },
    "Skill1": {
      "type": "ref",
      "target": "sounds.txt",
      "targetColumn": "Handle",
      "description": "Skill 1 sound effect"
    },
    "Skill2": {
      "type": "ref",
      "target": "sounds.txt",
      "targetColumn": "Handle",
      "description": "Skill 2 sound effect"
    },
    "Skill3": {
      "type": "ref",
      "target": "sounds.txt",
      "targetColumn": "Handle",
      "description": "Skill 3 sound effect"
    },
    "Skill4": {
      "type": "ref",
      "target": "sounds.txt",
      "targetColumn": "Handle",
      "description": "Skill 4 sound effect"
    },
    "Footstep": {
      "type": "ref",
      "target": "sounds.txt",
      "targetColumn": "Handle",
      "description": "Footstep sound effect"
    },
    "FootstepLayer": {
      "type": "ref",
      "target": "sounds.txt",
      "targetColumn": "Handle",
      "description": "Footstep layered/secondary sound effect"
