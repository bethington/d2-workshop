{
  "file": "setitems.txt",
  "description": "Set item definitions — maps individual set pieces to their base items, fixed (blue) properties, and partial/full set (green) bonus properties.",
  "columns": {
    "index": {
      "type": "string",
      "required": true,
      "unique": true,
      "description": "Unique identifier for this set item entry, used as a key by other files"
    },
    "set": {
      "type": "ref",
      "description": "Parent set this item belongs to",
      "target": "sets.txt",
      "targetColumn": "index"
    },
    "item": {
      "type": "string",
      "description": "Base item code referencing armor.txt, weapons.txt, or misc.txt code columns"
    },
    "*item": {
      "type": "string",
      "description": "Comment column — human-readable base item name for reference only"
    },
    "rarity": {
      "type": "integer",
      "description": "Relative rarity weight for drop selection among set items of the same base type"
    },
    "lvl": {
      "type": "integer",
      "min": 1,
      "max": 99,
      "description": "Internal item level used for affix generation and TC qualification"
    },
    "lvl req": {
      "type": "integer",
      "min": 0,
      "max": 99,
      "description": "Minimum character level required to equip this set item"
    },
    "chrtransform": {
      "type": "ref",
      "description": "Color transform applied to the character model when item is equipped",
      "target": "colors.txt",
      "targetColumn": "Code"
    },
    "invtransform": {
      "type": "ref",
      "description": "Color transform applied to the inventory graphic",
      "target": "colors.txt",
      "targetColumn": "Code"
    },
    "invfile": {
      "type": "string",
      "description": "Override inventory graphic DC6 filename (blank uses base item default)"
    },
    "flippyfile": {
      "type": "string",
      "description": "Override ground drop animation DC6 filename (blank uses base item default)"
    },
    "dropsound": {
      "type": "ref",
      "description": "Sound played when the item drops on the ground",
      "target": "sounds.txt",
      "targetColumn": "Handle"
    },
    "dropsfxframe": {
      "type": "integer",
      "description": "Animation frame on which the drop sound is triggered"
    },
    "usesound": {
      "type": "ref",
      "description": "Sound played when the item is picked up or equipped",
      "target": "sounds.txt",
      "targetColumn": "Handle"
    },
    "cost mult": {
      "type": "integer",
      "description": "Multiplier applied to the base item cost (in 1024ths, so 1024 = 1x)"
    },
    "cost add": {
      "type": "integer",
      "description": "Flat gold amount added to the item price after multiplication"
    },
    "add func": {
      "type": "integer",
      "min": 0,
      "max": 2,
      "description": "Controls how green (partial set) bonuses are applied: 0=none, 1=bonuses depend on which specific items are equipped, 2=bonuses depend on how many items are equipped"
    },
    "prop1": {
      "type": "ref",
      "description": "Fixed (blue) property 1 code applied when item is equipped",
      "target": "properties.txt",
      "targetColumn": "Code"
    },
    "par1": {
      "type": "string",
      "description": "Parameter for prop1 — skill ID, state ID, or other property-specific parameter"
    },
    "min1": {
      "type": "integer",
      "description": "Minimum value for prop1"
    },
    "max1": {
      "type": "integer",
      "description": "Maximum value for prop1"
    },
    "prop2": {
      "type": "ref",
      "description": "Fixed (blue) property 2 code",
      "target": "properties.txt",
      "targetColumn": "Code"
    },
    "par2": {
